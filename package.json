{
  "name": "jiandou",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/admin",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev-spring.sh",
    "dev:spring": "bash scripts/dev-spring.sh",
    "compose:dev": "bash scripts/compose-stack.sh dev up",
    "compose:dev:build": "bash scripts/compose-stack.sh dev build",
    "compose:dev:down": "bash scripts/compose-stack.sh dev down",
    "compose:dev:down:volumes": "bash scripts/compose-stack.sh dev down -v",
    "compose:dev:logs": "bash scripts/compose-stack.sh dev logs",
    "compose:dev:ps": "bash scripts/compose-stack.sh dev ps",
    "compose:prod": "bash scripts/compose-stack.sh prod up",
    "compose:prod:build": "bash scripts/compose-stack.sh prod build",
    "compose:prod:down": "bash scripts/compose-stack.sh prod down",
    "compose:prod:down:volumes": "bash scripts/compose-stack.sh prod down -v",
    "compose:prod:logs": "bash scripts/compose-stack.sh prod logs",
    "compose:prod:ps": "bash scripts/compose-stack.sh prod ps",
    "web:dev": "npm --workspace jiandou-web run dev",
    "web:build": "npm --workspace jiandou-web run build",
    "web:typecheck": "npm --workspace jiandou-web run typecheck",
    "admin:dev": "npm --workspace jiandou-admin run dev",
    "admin:build": "npm --workspace jiandou-admin run build",
    "admin:typecheck": "npm --workspace jiandou-admin run typecheck",
    "packages:build": "npm --workspaces --if-present run build --workspace @jiandou/api-client --workspace @jiandou/frontend-domain --workspace @jiandou/frontend-ui",
    "packages:typecheck": "npm --workspaces --if-present run typecheck --workspace @jiandou/api-client --workspace @jiandou/frontend-domain --workspace @jiandou/frontend-ui",
    "api:dev": "set -a; [ -f ./.env.dev ] && . ./.env.dev; set +a; export JIANDOU_DATABASE_URL=\"${JIANDOU_DATABASE_URL:-jdbc:mysql://127.0.0.1:3306/${MYSQL_DATABASE:-jiandou}?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai}\"; export JIANDOU_DATABASE_USER=\"${JIANDOU_DATABASE_USER:-${MYSQL_USER:-jiandou}}\"; export JIANDOU_DATABASE_PASSWORD=\"${JIANDOU_DATABASE_PASSWORD:-${MYSQL_PASSWORD:-}}\"; cd apps/api-spring && mvn -pl api-boot spring-boot:run",
    "api:spring:dev": "npm run api:dev",
    "api:test": "mvn -f apps/api-spring/pom.xml test",
    "generate:api": "bash scripts/generate-api.sh",
    "verify:architecture": "bash scripts/verify-architecture.sh",
    "verify:architecture:strict": "ARCH_CHECK_STRICT=1 bash scripts/verify-architecture.sh",
    "verify": "npm run verify:architecture && npm run packages:typecheck && npm run api:test && npm run web:typecheck && npm run admin:typecheck"
  },
  "devDependencies": {
    "openapi-fetch": "0.17.0",
    "openapi-typescript": "7.13.0"
  }
}
