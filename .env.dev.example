TZ=Asia/Shanghai

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=jiandou
MYSQL_USER=jiandou
MYSQL_PASSWORD=change-this-db-password
JIANDOU_MYSQL_PORT=3306

JIANDOU_WEB_PORT=80
JIANDOU_ADMIN_PORT=5174
JIANDOU_WEB_ORIGIN=http://127.0.0.1,http://localhost,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
JIANDOU_COOKIE_SECURE=false

JIANDOU_EXECUTION_MODE=queue
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_USERNAME=admin
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_DISPLAY_NAME=系统管理员
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_PASSWORD=change-this-admin-password

JIANDOU_PUBLIC_API_BASE_URL=/api/v3
JIANDOU_PUBLIC_STORAGE_BASE_URL=/storage
JIANDOU_STORAGE_PUBLIC_BASE_URL=
JIANDOU_PUBLIC_ADMIN_BASE_URL=http://127.0.0.1:5174

JIANDOU_MAVEN_IMAGE=maven:3.9.9-eclipse-temurin-21
JIANDOU_JAVA_IMAGE=eclipse-temurin:21-jre-jammy
JIANDOU_NODE_IMAGE=node:20-bookworm-slim
JIANDOU_NGINX_IMAGE=nginx:1.27-alpine
SPRING_THREADS_VIRTUAL_ENABLED=false
SPRING_MAIN_KEEP_ALIVE=false
JIANDOU_DB_POOL_MAX_SIZE=6
JIANDOU_DB_POOL_MIN_IDLE=1
JIANDOU_GENERATION_ASYNC_THREADS=2
JIANDOU_TASK_OPS_WORKER_CONCURRENCY=2
