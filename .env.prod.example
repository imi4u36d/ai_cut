TZ=Asia/Shanghai

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=jiandou
MYSQL_USER=jiandou
MYSQL_PASSWORD=change-this-db-password

JIANDOU_WEB_PORT=80
JIANDOU_WEB_ORIGIN=https://jiandou.org
JIANDOU_COOKIE_SECURE=false

JIANDOU_EXECUTION_MODE=queue
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_USERNAME=admin
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_DISPLAY_NAME=系统管理员
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_PASSWORD=change-this-admin-password

JIANDOU_PUBLIC_API_BASE_URL=/api/v2
JIANDOU_PUBLIC_STORAGE_BASE_URL=/storage

JIANDOU_MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9.9-eclipse-temurin-17
JIANDOU_JAVA_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:17-jre-jammy
JIANDOU_NODE_IMAGE=docker.m.daocloud.io/library/node:20-bookworm-slim
JIANDOU_NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine
