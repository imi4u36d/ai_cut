TZ=Asia/Shanghai

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=jiandou
MYSQL_USER=jiandou
MYSQL_PASSWORD=change-this-db-password
JIANDOU_MYSQL_PORT=3306

JIANDOU_WEB_PORT=80
JIANDOU_ADMIN_PORT=5174
JIANDOU_WEB_ORIGIN=https://jiandou.org,https://admin.jiandou.org
JIANDOU_COOKIE_SECURE=false

JIANDOU_EXECUTION_MODE=queue
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_USERNAME=admin
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_DISPLAY_NAME=系统管理员
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_PASSWORD=change-this-admin-password

JIANDOU_PUBLIC_API_BASE_URL=/api/v2
JIANDOU_PUBLIC_STORAGE_BASE_URL=/storage
JIANDOU_PUBLIC_ADMIN_BASE_URL=https://admin.jiandou.org

JIANDOU_MAVEN_IMAGE=docker.1ms.run/library/maven:3.9.9-eclipse-temurin-17
JIANDOU_JAVA_IMAGE=docker.1ms.run/library/eclipse-temurin:17-jre-jammy
JIANDOU_NODE_IMAGE=docker.1ms.run/library/node:20-bookworm-slim
JIANDOU_NGINX_IMAGE=docker.1ms.run/library/nginx:1.27-alpine
