TZ=Asia/Shanghai

JIANDOU_DATABASE_URL=jdbc:mysql://database-1.ctkcc2gii1xd.ap-northeast-1.rds.amazonaws.com:3306/jiandou?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=true
JIANDOU_DATABASE_USER=change-this-rds-user
JIANDOU_DATABASE_PASSWORD=change-this-rds-password

JIANDOU_WEB_PORT=80
JIANDOU_ADMIN_PORT=5174
JIANDOU_WEB_ORIGIN=https://jiandou.org,https://admin.jiandou.org
JIANDOU_COOKIE_SECURE=false

JIANDOU_EXECUTION_MODE=queue
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_USERNAME=admin
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_DISPLAY_NAME=系统管理员
JIANDOU_AUTH_BOOTSTRAP_INITIAL_ADMIN_PASSWORD=change-this-admin-password

JIANDOU_PUBLIC_API_BASE_URL=/api/v2
JIANDOU_PUBLIC_STORAGE_BASE_URL=/storage
JIANDOU_STORAGE_PUBLIC_BASE_URL=https://jiandou.org/storage
JIANDOU_PUBLIC_ADMIN_BASE_URL=https://admin.jiandou.org

JIANDOU_MAVEN_IMAGE=maven:3.9.9-eclipse-temurin-21
JIANDOU_JAVA_IMAGE=eclipse-temurin:21-jre-jammy
JIANDOU_NODE_IMAGE=node:20-bookworm-slim
JIANDOU_NGINX_IMAGE=nginx:1.27-alpine

SPRING_THREADS_VIRTUAL_ENABLED=true
SPRING_MAIN_KEEP_ALIVE=true
JIANDOU_DB_POOL_MAX_SIZE=3
JIANDOU_DB_POOL_MIN_IDLE=1
JIANDOU_GENERATION_ASYNC_THREADS=1
JIANDOU_TASK_OPS_WORKER_CONCURRENCY=1

JIANDOU_API_MEMORY_LIMIT=1536m
JIANDOU_API_CPUS=1.25
JIANDOU_WEB_MEMORY_LIMIT=128m
JIANDOU_WEB_CPUS=0.25
JIANDOU_ADMIN_MEMORY_LIMIT=128m
JIANDOU_ADMIN_CPUS=0.25
JIANDOU_GATEWAY_MEMORY_LIMIT=96m
JIANDOU_GATEWAY_CPUS=0.25
