{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@jiandou/api-client": ["../../packages/api-client/src/index.ts"],
      "@jiandou/api-client/generated": ["../../packages/api-client/src/generated/index.ts"],
      "@jiandou/frontend-domain": ["../../packages/frontend-domain/src/index.ts"],
      "@jiandou/frontend-ui": ["../../packages/frontend-ui/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "../../packages/api-client/src/**/*.ts",
    "../../packages/frontend-domain/src/**/*.ts",
    "../../packages/frontend-ui/src/**/*.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
